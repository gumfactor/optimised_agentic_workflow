#!/usr/bin/env bash
# Layer 1 pre-push hook — runs mandatory policy compliance check before every push.
# Install via: bash scripts/install-hooks.sh
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if [[ ! -f "$REPO_ROOT/scripts/policy-lint.sh" ]]; then
  echo "[pre-push] policy-lint.sh not found — skipping compliance check" >&2
  exit 0
fi

bash "$REPO_ROOT/scripts/policy-lint.sh"
